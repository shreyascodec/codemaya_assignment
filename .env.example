MONGODB_URI=          # MongoDB connection string (e.g. mongodb://localhost:27017/smartqa)
OPENAI_API_KEY=       # OpenAI key — gpt-4o-mini hits the sweet spot for cost/quality
JWT_SECRET=           # min 32 chars recommended, use a random hex string
JWT_EXPIRES_IN=1d
REDIS_URL=            # redis://localhost:6379 locally, rediss://... in prod
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
